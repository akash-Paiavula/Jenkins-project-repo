pipeline {
  agent any

  stages {
    stage("Checkout") {
      steps {
        checkout scmGit(branches: [[name: 'main']], extensions: [], userRemoteConfigs: [[url: 'https://github.com/akash-Paiavula/Jenkins-project-repo.git']])
      }
    }

    stage("Maven Build") {
      steps {
        sh """
          echo "-------- Building Application --------"
          mvn clean package
          echo "------- Application Built Successfully --------"
        """
      }
    }

}
}
